---
// Hero.astro — Section 1: split layout, headline + live YAML preview
import { Code } from 'astro:components';

const heroYaml = `brewspec_version: "1.0"
brews:
  - date: "2026-03-15"
    type: "pour_over"
    dose_g: 18
    water_g: 280
    water_temp_c: 93
    duration_s: 210
    coffee:
      name: "Ethiopia Yirgacheffe"
      roaster: "Onyx"
      roast_level: "light"
    result:
      tds: 1.38
      ey: 21.4
      tasting_notes: "Bergamot, lemon verbena"
      ratings:
        overall: 8
        flavour: 8
        acidity: 8`;
---
<section id="hero" class="dot-grid">
  <!-- SEO h1 — keyword-optimised, visually hidden -->
  <h1 class="hero-seo-h1">An open format for describing a coffee brew</h1>

  <div class="hero-layout wide-width">
    <!-- Left: text content -->
    <div class="hero-text">
      <p class="hero-eyebrow fade-in-1">Open format · v1.0 · Apache 2.0</p>
      <p class="hero-headline fade-in-2">Coffee brewing,<br>precisely described.</p>
      <p class="hero-subheadline fade-in-3">
        <span class="brewspec-wordmark">Brew<span class="brewspec-wordmark-accent">Spec</span></span>
        is a free, versioned data format for coffee brew records: method, dose,
        water, grind, extraction, result. Build tools on it, log brews locally,
        and move data between apps.
      </p>
      <div class="hero-ctas fade-in-4">
        <a href="/schema" class="btn btn-primary">View the schema</a>
        <a href="/#examples" class="btn btn-secondary">Browse examples</a>
      </div>
    </div>

    <!-- Right: YAML preview -->
    <div class="hero-code fade-in-5" aria-hidden="true">
      <div class="hero-code-chrome">
        <span class="chrome-dots" aria-hidden="true">
          <span class="chrome-dot"></span>
          <span class="chrome-dot"></span>
          <span class="chrome-dot"></span>
        </span>
        <span class="chrome-label">brew-record.yaml</span>
      </div>
      <div class="hero-code-body">
        <Code code={heroYaml} lang="yaml" theme="dark-plus" />
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    padding-top: calc(var(--space-2xl) + var(--space-lg));
    padding-bottom: calc(var(--space-2xl) + var(--space-lg));
    border-bottom: 1px solid var(--color-border);
    /* Position context for the dot-grid — no additional bg needed, class handles it */
  }

  /* Split layout: text left, code right */
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  /* ── Text column ── */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero-seo-h1 {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .hero-eyebrow {
    font-family: var(--font-head);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0;
  }

  .hero-headline {
    font-family: var(--font-head);
    font-size: var(--text-hero);  /* 68px */
    font-weight: var(--font-weight-bold);
    line-height: 1.08;
    color: var(--color-text);
    letter-spacing: -0.03em;
    margin-bottom: 0;
  }

  .brewspec-wordmark {
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
  }

  .brewspec-wordmark-accent {
    color: var(--color-accent);
  }

  .hero-subheadline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 0;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-xs);
  }

  /* ── Code column ── */
  .hero-code {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    /* Subtle border for definition in both modes */
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  @media (prefers-color-scheme: dark) {
    .hero-code {
      border: 1px solid rgba(255, 255, 255, 0.06);
    }
  }

  .hero-code-chrome {
    background-color: var(--color-code-surface);
    padding: 0.625rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .chrome-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .chrome-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.14);
  }

  .chrome-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.38);
    letter-spacing: 0.03em;
    margin-left: 0.25rem;
  }

  .hero-code-body :global(pre) {
    margin: 0;
    padding: var(--space-md) !important;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.65;
    overflow-x: auto;
  }

  .hero-code-body :global(code) {
    font-family: var(--font-mono);
  }

  /* ── Stagger animations ── */
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in-1 { animation: fade-up 0.55s var(--ease-out) both; animation-delay: 0ms; }
  .fade-in-2 { animation: fade-up 0.55s var(--ease-out) both; animation-delay: 80ms; }
  .fade-in-3 { animation: fade-up 0.55s var(--ease-out) both; animation-delay: 160ms; }
  .fade-in-4 { animation: fade-up 0.55s var(--ease-out) both; animation-delay: 240ms; }
  .fade-in-5 { animation: fade-up 0.65s var(--ease-out) both; animation-delay: 200ms; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .hero-headline {
      font-size: var(--text-5xl);  /* 56px */
    }

    .hero-code {
      /* Show on tablet — still valuable */
      max-width: 560px;
    }
  }

  @media (max-width: 639px) {
    #hero {
      padding-top: var(--space-2xl);
      padding-bottom: var(--space-xl);
    }

    .hero-headline {
      font-size: var(--text-4xl);  /* 44px */
      letter-spacing: -0.02em;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-code {
      display: none;  /* Too compact on small mobile */
    }
  }
</style>
