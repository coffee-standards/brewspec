---
// Examples.astro — Section 3: two code blocks side-by-side
// NOTE: The espresso example uses the corrected version from design doc Section 1.3
// (all 8 SCA rating dimensions). Do NOT revert to the copy doc version which omits
// fragrance, aroma, and sweetness.
import CodeBlock from './CodeBlock.astro';

const pourOverYaml = `brewspec_version: "1.0"
brews:
  - date: "2026-02-25"
    type: "pour_over"
    dose_g: 18
    water_g: 280`;

// Full espresso example — all 8 SCA rating dimensions present:
// overall, fragrance, aroma, flavour, acidity, aftertaste, sweetness, mouthfeel
// v1.0: water_g (renamed from water_weight_g), process_notes (renamed from notes),
// and new equipment fields pressure_bar and flow_rate_ml_s.
const espressoYaml = `brewspec_version: "1.0"
brews:
  - date: "2026-02-25T08:30:00Z"
    type: "espresso"
    dose_g: 18
    water_g: 36
    water_temp_c: 94
    grind: "espresso"
    duration_s: 28
    method: "La Marzocco Linea Mini"
    process_notes: "Re-calibrated grinder after three weeks"
    coffee:
      name: "El Paraiso Washed Castillo"
      roaster: "Onyx"
      roast_level: "medium"
      roast_date: "2026-02-10"
      type: "single_origin"
      origins:
        - country: "Colombia"
          region: "Huila"
          varietal: "Castillo"
          elevation_masl: 1800
    water:
      ppm: 120
    equipment:
      grinder: "Niche Zero"
      brewer: "La Marzocco Linea Mini"
      pressure_bar: 9.0
      flow_rate_ml_s: 1.8
    result:
      yield_g: 36
      tds: 9.2
      ey: 19.8
      brix: 4.6
      tasting_notes: "Dark chocolate, orange peel, long clean finish"
      ratings:
        overall: 7
        fragrance: 7
        aroma: 7
        flavour: 8
        acidity: 7
        aftertaste: 7
        sweetness: 6
        mouthfeel: 6`;
---
<section id="examples">
  <div class="wide-width">
    <h2>See what a brew looks like.</h2>
    <p class="section-intro">
      A minimal record. A full espresso record with yield and ratings.
    </p>

    <div class="examples-grid">
      <CodeBlock
        label="Pour over — minimal record"
        code={pourOverYaml}
        language="yaml"
      />
      <CodeBlock
        label="Espresso — full record"
        code={espressoYaml}
        language="yaml"
      />
    </div>
  </div>
</section>

<style>
  .section-intro {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .examples-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  @media (max-width: 767px) {
    .examples-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
