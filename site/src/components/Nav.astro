---
// Nav.astro — Navigation bar
// Frosted glass on scroll via backdrop-filter. Only JS on the page (~5 lines inline).
const currentPath = Astro.url.pathname;
---
<header class="site-header">
  <nav class="nav" aria-label="Main navigation">
    <div class="nav-inner content-width">
      <a href="/" class="nav-wordmark" aria-label="BrewSpec home">Brew<span class="nav-wordmark-accent">Spec</span></a>

      <button
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-links"
        aria-label="Toggle navigation menu"
      >
        <span class="nav-toggle-open" aria-hidden="true">&#9776;</span>
        <span class="nav-toggle-close" aria-hidden="true">&#10005;</span>
      </button>

      <ul id="nav-links" class="nav-links" role="list">
        <li>
          <a
            href="/schema"
            class={`nav-link${currentPath === '/schema' ? ' nav-link--active' : ''}`}
          >Schema</a>
        </li>
        <li>
          <a
            href="https://github.com/coffee-standards/brewspec/blob/main/brewspec-v0.9.md"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link"
          >Spec</a>
        </li>
        <li>
          <a href="/#examples" class="nav-link">Examples</a>
        </li>
        <li>
          <a
            href="https://github.com/coffee-standards/brewspec"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link nav-link--github"
          >GitHub</a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    /* Frosted glass — backdrop blur.
       color-mix used to derive semi-transparent bg from the token (no hardcoded hex). */
    background-color: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);  /* 60px */
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-sm);
  }

  .nav-wordmark {
    font-family: var(--font-head);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    color: var(--color-text);
    letter-spacing: -0.02em;
    transition: opacity 0.15s ease;
  }

  .nav-wordmark:hover {
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.75;
  }

  .nav-wordmark-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    font-family: var(--font-head);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: 0.25rem 0;
    position: relative;
    transition: color 0.15s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background-color: var(--color-accent);
    transition: width 0.2s var(--ease-out);
    border-radius: 2px;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link--active {
    color: var(--color-text);
  }

  .nav-link--active::after {
    width: 100%;
  }

  .nav-link--github {
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }

  .nav-link--github::after {
    display: none;
  }

  .nav-link--github:hover {
    border-color: var(--color-text-muted);
    background-color: var(--color-surface);
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    font-size: var(--text-xl);
    line-height: 1;
    padding: var(--space-xs);
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .nav-toggle-close {
    display: none;
  }

  /* Mobile styles */
  @media (max-width: 639px) {
    .nav-inner {
      flex-wrap: wrap;
      height: auto;
      padding: var(--space-xs) var(--space-sm);
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
      width: 100%;
      padding: var(--space-xs) 0 var(--space-sm) 0;
    }

    .nav--open .nav-links {
      display: flex;
    }

    .nav--open .nav-toggle-open {
      display: none;
    }

    .nav--open .nav-toggle-close {
      display: inline;
    }

    .nav-link {
      font-size: var(--text-lg);
      padding: var(--space-xs) 0;
    }

    .nav-link--github {
      font-size: var(--text-sm);
      margin-top: var(--space-xs);
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.querySelector('.nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('nav--open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
