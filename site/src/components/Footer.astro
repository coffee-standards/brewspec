---
// Footer.astro — Site footer with CTAs and attribution
---
<footer class="site-footer">
  <div class="content-width footer-inner">
    <div class="footer-top">
      <p class="footer-wordmark">Brew<span class="footer-wordmark-accent">Spec</span></p>
      <p class="footer-tagline">An open format for coffee brews.</p>
    </div>

    <div class="footer-ctas">
      <div class="footer-cta-item">
        <a href="/schema" class="btn btn-primary">View the schema</a>
        <p class="cta-subtext">brewspec.coffee/schema</p>
      </div>

      <div class="footer-cta-item">
        <a
          href="https://github.com/coffee-standards/brewspec"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
        >Try BrewLog</a>
        <p class="cta-subtext">github.com/coffee-standards/brewspec</p>
      </div>
    </div>

    <p class="footer-attribution">
      BrewSpec is open source software released under the Apache 2.0 License.
      Schema and spec maintained at
      <a
        href="https://github.com/coffee-standards/brewspec"
        target="_blank"
        rel="noopener noreferrer"
      >github.com/coffee-standards/brewspec</a>.
      Questions? <a href="mailto:hello@brewspec.coffee">hello@brewspec.coffee</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-wordmark {
    font-family: var(--font-head);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }

  .footer-wordmark-accent {
    color: var(--color-accent);
  }

  .footer-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer-ctas {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .footer-cta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cta-subtext {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    margin: 0;
    font-family: var(--font-mono);
  }

  .footer-attribution {
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-md);
    margin: 0;
    line-height: 1.65;
  }

  .footer-attribution a {
    color: var(--color-text-muted);
    text-decoration-color: var(--color-border);
  }

  .footer-attribution a:hover {
    color: var(--color-text);
  }

  @media (max-width: 639px) {
    .footer-ctas {
      flex-direction: column;
    }
  }
</style>
